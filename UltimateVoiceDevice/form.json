{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "Server-Verbindung",
            "expanded": true,
            "items": [
                {
                    "name": "ServerURL",
                    "type": "ValidationTextBox",
                    "caption": "Server URL",
                    "width": "400px",
                    "value": "https://voice.smarthome-services.xyz"
                },
                {
                    "name": "APIKey",
                    "type": "PasswordTextBox",
                    "caption": "API Key",
                    "width": "400px"
                },
                {
                    "name": "CharacterID",
                    "type": "ValidationTextBox",
                    "caption": "Charakter-ID",
                    "width": "250px",
                    "value": "butler_de"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Ausgabe (Echo / Alexa)",
            "expanded": true,
            "items": [
                {
                    "name": "EchoRemoteID",
                    "type": "SelectInstance",
                    "caption": "EchoRemote Instanz",
                    "width": "400px",
                    "moduleID": "{496AB8B5-396A-40E4-AF41-32F4AA6F5404}"
                },
                {
                    "name": "DeliveryMode",
                    "type": "Select",
                    "caption": "Auslieferungs-Modus",
                    "width": "350px",
                    "value": "userdir",
                    "options": [
                        { "caption": "IPS /user/-Verzeichnis via Connect (Free)", "value": "userdir" },
                        { "caption": "Webhook via IPS Connect (experimentell)", "value": "webhook" },
                        { "caption": "Direkt vom Server (Premium)", "value": "direct" }
                    ]
                },
                {
                    "type": "Label",
                    "caption": "UserDir: MP3 im /user/-Verzeichnis, Alexa holt via IPMagic-URL.",
                    "italic": true
                },
                {
                    "type": "Label",
                    "caption": "Direkt: Alexa holt Audio direkt vom Ultimate Voice Server. Erfordert Premium-Abo.",
                    "italic": true
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "ExpansionPanel",
            "caption": "Test",
            "expanded": true,
            "items": [
                {
                    "type": "Select",
                    "name": "TestEventType",
                    "caption": "Test-Event",
                    "value": "doorbell",
                    "options": [
                        { "caption": "Klingel (doorbell)", "value": "doorbell" },
                        { "caption": "Batterie leer (battery_low)", "value": "battery_low" },
                        { "caption": "Waschmaschine fertig (washer_done)", "value": "washer_done" },
                        { "caption": "Fenster offen (window_open)", "value": "window_open" },
                        { "caption": "Bewegung (motion_detected)", "value": "motion_detected" },
                        { "caption": "Willkommen (welcome)", "value": "welcome" },
                        { "caption": "Auf Wiedersehen (goodbye)", "value": "goodbye" },
                        { "caption": "Temperatur-Alarm (temperature_alert)", "value": "temperature_alert" },
                        { "caption": "Regen (rain_alert)", "value": "rain_alert" },
                        { "caption": "Timer fertig (timer_done)", "value": "timer_done" }
                    ]
                },
                {
                    "type": "Button",
                    "caption": "Sprechen (Cache)",
                    "onClick": "echo UVD_TestSpeak($id, $TestEventType);"
                },
                {
                    "type": "Button",
                    "caption": "Neu generieren (LLM-Test)",
                    "onClick": "echo UVD_ForceSpeak($id, $TestEventType);"
                },
                {
                    "type": "Button",
                    "caption": "Webhook Status prüfen",
                    "onClick": "echo UVD_GetWebhookStatus($id);"
                },
                {
                    "type": "Button",
                    "caption": "Lokalen Cache leeren",
                    "onClick": "echo UVD_ClearCache($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Direkte Nutzung in IPS-Skripten: UVD_Speak($instanzId, 'doorbell');",
            "italic": true,
            "bold": false
        }
    ],
    "status": []
}
